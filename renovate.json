{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "enabledManagers": [
    "custom.regex"
  ],
  "ignorePaths": [],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^custom_components/esphome_mcp/const\\.py$/"
      ],
      "matchStrings": [
        "DEFAULT_PIP_SPEC\\s*=\\s*[\"']fastmcp==(?<currentValue>\\d+\\.\\d+\\.\\d+(?:(?:a|b|rc)\\d+)?)[\"']"
      ],
      "depNameTemplate": "fastmcp",
      "datasourceTemplate": "pypi",
      "versioningTemplate": "pep440"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^tests/haos_image_build/build_image\\.py$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=home-assistant/operating-system\\s+HAOS_VERSION\\s*=\\s*[\"'](?<currentValue>\\d+\\.\\d+(?:\\.\\d+)?)[\"']"
      ],
      "depNameTemplate": "home-assistant/operating-system",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "description": "FastMCP runtime pin validated against ha-mcp master",
      "matchDatasources": [
        "pypi"
      ],
      "matchPackageNames": [
        "fastmcp"
      ],
      "labels": [
        "dependencies",
        "python",
        "compatibility"
      ]
    },
    {
      "description": "Home Assistant OS image version used by HAOS E2E",
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "home-assistant/operating-system"
      ],
      "labels": [
        "dependencies",
        "haos",
        "e2e"
      ]
    }
  ],
  "labels": [
    "dependencies"
  ]
}
