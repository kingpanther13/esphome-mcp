{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "UTC",
  "enabledManagers": [
    "custom.regex"
  ],
  "ignorePaths": [],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/custom_components/esphome_mcp/const\\.py$/",
        "/tests/.*\\.py$/",
        "/.github/workflows/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+[A-Z0-9_]+\\s*=\\s*[\"']?(?<currentValue>[\\w.+-]+)[\"']?",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+\\S+:\\s*[\"']?(?<currentValue>[\\w.+-]+)[\"']?",
        "DEFAULT_PIP_SPEC\\s*=\\s*[\"']fastmcp==(?<currentValue>\\d+\\.\\d+\\.\\d+(?:(?:a|b|rc)\\d+)?)[\"']\\s*# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ],
      "depNameTemplate": "{{{depName}}}",
      "datasourceTemplate": "{{{datasource}}}"
    }
  ],
  "packageRules": [
    {
      "description": "FastMCP runtime pin validated against ha-mcp master",
      "matchDatasources": [
        "pypi"
      ],
      "matchPackageNames": [
        "fastmcp"
      ],
      "labels": [
        "dependencies",
        "python",
        "compatibility"
      ]
    },
    {
      "description": "Home Assistant OS image version used by HAOS E2E",
      "matchDatasources": [
        "github-releases"
      ],
      "matchPackageNames": [
        "home-assistant/operating-system"
      ],
      "labels": [
        "dependencies",
        "haos",
        "e2e"
      ]
    }
  ],
  "labels": [
    "dependencies"
  ]
}
